<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTargetNumber"
        android:layout_width="120dp"
        android:layout_height="90dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/input_bg"
        android:backgroundTint="#1E293B"
        android:gravity="center"
        android:text="@string/placeholder_three"
        android:textColor="@color/primary"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/numbersContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTargetNumber">

        <TextView style="@style/StepStyle" android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\?" android:textSize="12sp"/>
        <TextView style="@style/StepStyle" android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\?" android:textSize="12sp"/>
        <TextView style="@style/StepStyle" android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\?" android:textSize="12sp"/>
        <TextView style="@style/StepStyle" android:layout_width="45dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\?" android:textSize="12sp"/>
        <TextView style="@style/StepStyle" android:layout_width="55dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\??" android:textSize="12sp"/>
        <TextView style="@style/StepStyle" android:layout_width="65dp" android:layout_height="45dp" android:layout_margin="2dp" android:text="\?\??" android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/input_bg"
        android:gravity="center_vertical"
        android:hint="Vaš izraz..."
        android:padding="16dp"
        android:textColor="@color/text"
        android:textColorHint="@color/hint"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/numbersContainer" />

    <GridLayout
        android:id="@+id/operandsGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:columnCount="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvExpression">

        <Button style="@style/OperandBtn" android:text="+" />
        <Button style="@style/OperandBtn" android:text="-" />
        <Button style="@style/OperandBtn" android:text="*" />
        <Button style="@style/OperandBtn" android:text="/" />
        <Button style="@style/OperandBtn" android:text="(" />
        <Button style="@style/OperandBtn" android:text=")" />
    </GridLayout>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="STOP / SHAKE"
        android:textColor="@color/text"
        android:backgroundTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>